rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isParticipant(chatId) {
      return signedIn() && exists(/databases/$(database)/documents/chats/$(chatId)/members/$(request.auth.uid));
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;

      match /friendRequests/{requestId} {
        allow read: if signedIn() && (resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid);
        allow create: if signedIn() && request.resource.data.fromUserId == request.auth.uid;
        allow update: if signedIn() && resource.data.toUserId == request.auth.uid;
        allow delete: if false;
      }

      match /friends/{friendId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      match /nearbyEncounters/{encounterId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
    }

    match /presence/{userId} {
      allow read: if signedIn();
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /stories/{storyId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /chats/{chatId} {
      allow read: if isParticipant(chatId);
      allow create: if signedIn();
      allow update: if isParticipant(chatId);
      allow delete: if false;

      match /members/{memberId} {
        allow read: if isParticipant(chatId);
        allow write: if false;
      }
    }

    match /messages/{messageId} {
      allow read: if isParticipant(resource.data.chatId);
      allow create: if signedIn() && isParticipant(request.resource.data.chatId) && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
